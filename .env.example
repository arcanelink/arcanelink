# ArcaneLink Environment Variables Example
# Copy this file to .env and modify as needed

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
GRPC_PORT=50051

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mbot
DB_USER=mbot
DB_PASSWORD=mbot_password
DB_SSL_MODE=disable

# Redis Configuration
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Microservices Addresses
AUTH_SERVICE_ADDR=localhost:50051
MESSAGE_SERVICE_ADDR=localhost:50052
ROOM_SERVICE_ADDR=localhost:50053
PRESENCE_SERVICE_ADDR=localhost:54054
FEDERATION_SERVICE_ADDR=localhost:50055

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=86400

# Optional: Service-specific overrides
# Uncomment and modify for specific services

# API Gateway
# SERVER_PORT=8080

# Auth Service
# GRPC_PORT=50051

# Message Service
# GRPC_PORT=50052

# Room Service
# GRPC_PORT=50053

# Presence Service
# GRPC_PORT=50054

# Federation Service
# GRPC_PORT=50055
